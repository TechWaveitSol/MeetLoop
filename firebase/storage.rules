rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to verify user ownership
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to validate uploaded files (must be image and < 5MB)
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024;
    }

    // Match path for user profile photos
    match /users/{userId}/profile_images/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidImage();
    }

    // Match path for user verification files
    match /users/{userId}/verification/{allPaths=**} {
      allow read, write: if isOwner(userId) && isValidImage();
    }
  }
}
