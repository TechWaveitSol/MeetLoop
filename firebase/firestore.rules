rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the record
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to validate schema of user profile
    function isValidUserProfile(data) {
      return data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.createdAt is string &&
             data.isEmailVerified is bool;
    }

    // Match users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt', 'uid']));
      allow delete: if isOwner(userId);
      
      // Match active sessions subcollection
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Match chats collection
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      
      // Match messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }
  }
}
